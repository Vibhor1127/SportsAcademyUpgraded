<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fitness-Club</title>
    <%@include file= "/common_files/common_css.html" %>
    <%@ include file="/common_files/common_header.html" %>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #4158D0;
background-image: linear-gradient(43deg, #4158D0 0%, #C850C0 46%, #FFCC70 100%);

            background-size: cover;
            margin: 0;
            padding: 0;
            color: white;
            text-align: center;
        }

        .heading {
            font-size: 3em;
            margin-top: 50px;
            animation: fadeIn 2s ease-in;
        }

        .description {
            margin: 20px auto;
            width: 80%;
            font-size: 1.2em;
            background-color: rgba(0, 0, 0, 0.6);
            padding: 20px;
            border-radius: 10px;
            animation: slideIn 2s ease-in;
        }

        .image-container {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            margin: 20px;
            animation: fadeIn 3s ease-in;
        }

        .image-container img {
            width: 300px;
            height: 200px;
            margin: 10px;
            border-radius: 10px;
            transition: transform 0.3s;
        }

        .image-container img:hover {
            transform: scale(1.1);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        @keyframes slideIn {
            from {
                transform: translateY(100%);
            }
            to {
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
<div class="main_body">
    <h1 class="heading">Fitness-Club</h1>
    <div class="description">
       A health club (also known as a fitness club, fitness center, health spa, weight room and commonly referred to as a gym) is a place that houses exercise equipment for the purpose of physical exercise.
    </div>
    <div class="image-container">
        <img src="data:image/jpeg;base64," alt="Cafeteria Image 1"> 
        <img src="data:image/jpeg;base64," alt="Cafeteria Image 2"> 
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQe8iZxO38cr8rsGqRadkqhJdyp5uWzQzzjSQ&s" alt="Cafeteria Image 3"> 
    </div>
    </div>
    <%@include file ="/common_files/Common_footer.html" %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    
</body>
</html>
